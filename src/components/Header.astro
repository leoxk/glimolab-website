---
/**
 * GlimoLab Header — responsive navigation bar
 * Logo (left) · nav links (center) · language switcher + CTA (right)
 * Adds a backdrop-blur background once the user scrolls.
 */
import { useTranslations, getLangFromUrl, localizePath, getLanguages } from '@i18n/utils';
import { defaultLang, type Lang } from '@i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const languages = getLanguages();

const navLinks = [
  { key: 'nav.home' as const, href: '/' },
  { key: 'nav.about' as const, href: '/about' },
  { key: 'nav.services' as const, href: '/services' },
  { key: 'nav.portfolio' as const, href: '/portfolio' },
  { key: 'nav.pricing' as const, href: '/pricing' },
  { key: 'nav.blog' as const, href: '/blog' },
  { key: 'nav.contact' as const, href: '/contact' },
];

const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a
      href={localizePath('/', lang)}
      class="flex items-center gap-2 text-white transition-opacity hover:opacity-80"
      aria-label="GlimoLab home"
    >
      <svg width="36" height="36" viewBox="0 0 48 48" fill="none" class="shrink-0" aria-hidden="true">
        <g stroke-linecap="round">
          <!-- Connection lines: G path (outer ring) -->
          <line x1="29" y1="8" x2="41" y2="24" stroke="#0066FF" stroke-width="0.8" opacity="0.5"/>
          <line x1="41" y1="24" x2="39" y2="33" stroke="#0088DD" stroke-width="0.8" opacity="0.5"/>
          <line x1="39" y1="33" x2="33" y2="40" stroke="#0099DD" stroke-width="0.8" opacity="0.5"/>
          <line x1="33" y1="40" x2="24" y2="42" stroke="#00AADD" stroke-width="0.8" opacity="0.5"/>
          <line x1="24" y1="42" x2="15" y2="40" stroke="#00BCD4" stroke-width="0.8" opacity="0.5"/>
          <line x1="15" y1="40" x2="9" y2="33" stroke="#00BCD4" stroke-width="0.8" opacity="0.5"/>
          <line x1="9" y1="33" x2="7" y2="24" stroke="#0099DD" stroke-width="0.8" opacity="0.5"/>
          <line x1="7" y1="24" x2="9" y2="15" stroke="#0088DD" stroke-width="0.8" opacity="0.5"/>
          <line x1="9" y1="15" x2="15" y2="8" stroke="#0077CC" stroke-width="0.8" opacity="0.5"/>
          <line x1="15" y1="8" x2="24" y2="6" stroke="#0066FF" stroke-width="0.8" opacity="0.5"/>
          <line x1="24" y1="6" x2="29" y2="8" stroke="#0066FF" stroke-width="0.8" opacity="0.5"/>
          <!-- Crossbar -->
          <line x1="41" y1="24" x2="34" y2="24" stroke="#0088DD" stroke-width="0.8" opacity="0.5"/>
          <line x1="34" y1="24" x2="24" y2="24" stroke="#0077CC" stroke-width="0.8" opacity="0.5"/>
          <!-- Spoke lines: outer → center -->
          <line x1="24" y1="6" x2="24" y2="24" stroke="#0066FF" stroke-width="0.5" opacity="0.25"/>
          <line x1="29" y1="8" x2="24" y2="24" stroke="#0066FF" stroke-width="0.5" opacity="0.25"/>
          <line x1="15" y1="8" x2="24" y2="24" stroke="#0066FF" stroke-width="0.5" opacity="0.25"/>
          <line x1="9" y1="15" x2="24" y2="24" stroke="#0077CC" stroke-width="0.5" opacity="0.25"/>
          <line x1="7" y1="24" x2="24" y2="24" stroke="#0099DD" stroke-width="0.5" opacity="0.25"/>
          <line x1="9" y1="33" x2="24" y2="24" stroke="#00AADD" stroke-width="0.5" opacity="0.25"/>
          <line x1="15" y1="40" x2="24" y2="24" stroke="#00BCD4" stroke-width="0.5" opacity="0.25"/>
          <line x1="24" y1="42" x2="24" y2="24" stroke="#00BCD4" stroke-width="0.5" opacity="0.25"/>
          <line x1="33" y1="40" x2="24" y2="24" stroke="#00BCD4" stroke-width="0.5" opacity="0.25"/>
          <line x1="39" y1="33" x2="24" y2="24" stroke="#00AADD" stroke-width="0.5" opacity="0.25"/>
          <!-- Cross mesh: skip-one connections -->
          <line x1="24" y1="6" x2="15" y2="15" stroke="#0066FF" stroke-width="0.5" opacity="0.2"/>
          <line x1="29" y1="8" x2="34" y2="16" stroke="#0066FF" stroke-width="0.5" opacity="0.2"/>
          <line x1="9" y1="15" x2="15" y2="32" stroke="#0088DD" stroke-width="0.5" opacity="0.2"/>
          <line x1="7" y1="24" x2="15" y2="40" stroke="#0099DD" stroke-width="0.5" opacity="0.2"/>
          <line x1="15" y1="8" x2="7" y2="24" stroke="#0077CC" stroke-width="0.5" opacity="0.2"/>
          <line x1="33" y1="40" x2="39" y2="33" stroke="#00BCD4" stroke-width="0.5" opacity="0.2"/>
          <!-- Inner mesh: outer → inner ring -->
          <line x1="24" y1="6" x2="24" y2="14" stroke="#0066FF" stroke-width="0.5" opacity="0.2"/>
          <line x1="15" y1="8" x2="17" y2="16" stroke="#0066FF" stroke-width="0.5" opacity="0.2"/>
          <line x1="29" y1="8" x2="31" y2="16" stroke="#0066FF" stroke-width="0.5" opacity="0.2"/>
          <line x1="9" y1="15" x2="16" y2="20" stroke="#0077CC" stroke-width="0.5" opacity="0.2"/>
          <line x1="7" y1="24" x2="14" y2="24" stroke="#0099DD" stroke-width="0.5" opacity="0.2"/>
          <line x1="9" y1="33" x2="16" y2="28" stroke="#00AADD" stroke-width="0.5" opacity="0.2"/>
          <line x1="15" y1="40" x2="18" y2="33" stroke="#00BCD4" stroke-width="0.5" opacity="0.2"/>
          <line x1="24" y1="42" x2="24" y2="34" stroke="#00BCD4" stroke-width="0.5" opacity="0.2"/>
          <line x1="33" y1="40" x2="31" y2="32" stroke="#00BCD4" stroke-width="0.5" opacity="0.2"/>
          <line x1="39" y1="33" x2="32" y2="28" stroke="#00AADD" stroke-width="0.5" opacity="0.2"/>
          <line x1="41" y1="24" x2="34" y2="20" stroke="#0088DD" stroke-width="0.5" opacity="0.2"/>
        </g>
        <!-- Inner ring nodes -->
        <circle cx="24" cy="14" r="1.3" fill="#0066FF"/>
        <circle cx="17" cy="16" r="1.3" fill="#0066FF"/>
        <circle cx="31" cy="16" r="1.3" fill="#0066FF"/>
        <circle cx="16" cy="20" r="1.3" fill="#0077CC"/>
        <circle cx="14" cy="24" r="1.3" fill="#0099DD"/>
        <circle cx="16" cy="28" r="1.3" fill="#00AADD"/>
        <circle cx="18" cy="33" r="1.3" fill="#00BCD4"/>
        <circle cx="24" cy="34" r="1.3" fill="#00BCD4"/>
        <circle cx="31" cy="32" r="1.3" fill="#00BCD4"/>
        <circle cx="32" cy="28" r="1.3" fill="#00AADD"/>
        <circle cx="34" cy="20" r="1.3" fill="#0088DD"/>
        <!-- Crossbar node -->
        <circle cx="34" cy="24" r="1.8" fill="#0088DD"/>
        <!-- Outer G-path nodes -->
        <circle cx="24" cy="6" r="2" fill="#0066FF"/>
        <circle cx="29" cy="8" r="2" fill="#0066FF"/>
        <circle cx="41" cy="24" r="2" fill="#0088DD"/>
        <circle cx="39" cy="33" r="2" fill="#0099DD"/>
        <circle cx="33" cy="40" r="2" fill="#00AADD"/>
        <circle cx="24" cy="42" r="2" fill="#00BCD4"/>
        <circle cx="15" cy="40" r="2" fill="#00BCD4"/>
        <circle cx="9" cy="33" r="2" fill="#00AADD"/>
        <circle cx="7" cy="24" r="2" fill="#0099DD"/>
        <circle cx="9" cy="15" r="2" fill="#0088DD"/>
        <circle cx="15" cy="8" r="2" fill="#0066FF"/>
        <!-- Center glow + node -->
        <circle cx="24" cy="24" r="7" fill="url(#hdr-cg)" opacity="0.35"/>
        <circle cx="24" cy="24" r="3.5" fill="#0066FF"/>
        <defs>
          <radialGradient id="hdr-cg" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#66D9FF" stop-opacity="0.9"/>
            <stop offset="100%" stop-color="#0066FF" stop-opacity="0"/>
          </radialGradient>
        </defs>
      </svg>
      <span class="font-heading text-xl font-bold tracking-tight">
        Glimo<span class="text-primary">Lab</span>
      </span>
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden items-center gap-1 lg:flex">
      {navLinks.map((link) => {
        const isActive =
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={localizePath(link.href, lang)}
              class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
                isActive
                  ? 'text-white'
                  : 'text-text-muted hover:text-white'
              }`}
            >
              {t(link.key)}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Right cluster: language switcher + CTA -->
    <div class="flex items-center gap-3">
      <!-- Language switcher -->
      <div class="relative hidden sm:block" id="lang-switcher">
        <button
          type="button"
          id="lang-toggle"
          class="flex items-center gap-1 rounded-lg border border-dark-border px-2.5 py-2 text-sm text-text-light transition-colors hover:border-primary"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
          <span class="uppercase">{lang}</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>
        <ul
          id="lang-menu"
          class="invisible absolute right-0 mt-2 w-40 overflow-hidden rounded-lg border border-dark-border bg-dark-surface opacity-0 shadow-card transition-all duration-200"
          role="menu"
        >
          {(Object.entries(languages) as [Lang, string][]).map(([code, label]) => (
            <li>
              <a
                href={localizePath(currentPath, code)}
                class={`flex items-center px-4 py-2.5 text-sm transition-colors hover:bg-dark-border ${
                  code === lang ? 'text-primary' : 'text-text-light'
                }`}
                role="menuitem"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA button -->
      <a
        href={localizePath('/contact', lang)}
        class="hidden rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90 hover:shadow-lg sm:inline-block"
      >
        {t('cta.getStarted')}
      </a>

      <!-- Mobile hamburger -->
      <button
        type="button"
        id="menu-toggle"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-text-light transition-colors hover:bg-dark-surface lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-dark-border bg-dark-bg/95 backdrop-blur-lg lg:hidden"
  >
    <ul class="space-y-1 px-4 py-4">
      {navLinks.map((link) => {
        const isActive =
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={localizePath(link.href, lang)}
              class={`block rounded-lg px-4 py-2.5 text-base font-medium transition-colors ${
                isActive ? 'bg-dark-surface text-white' : 'text-text-muted hover:bg-dark-surface hover:text-white'
              }`}
            >
              {t(link.key)}
            </a>
          </li>
        );
      })}
      <li class="pt-2">
        <!-- Language switcher (mobile) -->
        <div class="flex flex-wrap gap-2">
          {(Object.entries(languages) as [Lang, string][]).map(([code, label]) => (
            <a
              href={localizePath(currentPath, code)}
              class={`rounded-md border px-3 py-1.5 text-xs font-medium uppercase transition-colors ${
                code === lang
                  ? 'border-primary bg-primary/10 text-primary'
                  : 'border-dark-border text-text-muted hover:text-white'
              }`}
            >
              {code}
            </a>
          ))}
        </div>
      </li>
      <li class="pt-3">
        <a
          href={localizePath('/contact', lang)}
          class="block rounded-lg bg-primary px-5 py-3 text-center text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90"
        >
          {t('cta.getStarted')}
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-20"></div>

<script>
  // --- Scroll: toggle backdrop blur on the header ---
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    const scrolled = window.scrollY > 8;
    header.setAttribute('data-scrolled', String(scrolled));
    if (scrolled) {
      header.classList.add('bg-dark-bg/80', 'backdrop-blur-lg', 'border-b', 'border-dark-border', 'shadow-card');
    } else {
      header.classList.remove('bg-dark-bg/80', 'backdrop-blur-lg', 'border-b', 'border-dark-border', 'shadow-card');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // --- Mobile menu toggle ---
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  menuToggle?.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // --- Language dropdown ---
  const langToggle = document.getElementById('lang-toggle');
  const langMenu = document.getElementById('lang-menu');
  const langSwitcher = document.getElementById('lang-switcher');
  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = langToggle.getAttribute('aria-expanded') === 'true';
    langToggle.setAttribute('aria-expanded', String(!expanded));
    if (langMenu) {
      if (expanded) {
        langMenu.classList.add('invisible', 'opacity-0');
        langMenu.classList.remove('visible', 'opacity-100');
      } else {
        langMenu.classList.remove('invisible', 'opacity-0');
        langMenu.classList.add('visible', 'opacity-100');
      }
    }
  });
  // Close language menu on outside click
  document.addEventListener('click', (e) => {
    if (langSwitcher && !langSwitcher.contains(e.target as Node)) {
      langToggle?.setAttribute('aria-expanded', 'false');
      langMenu?.classList.add('invisible', 'opacity-0');
      langMenu?.classList.remove('visible', 'opacity-100');
    }
  });
</script>
