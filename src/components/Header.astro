---
/**
 * GlimoLab Header — responsive navigation bar
 * Logo (left) · nav links (center) · language switcher + CTA (right)
 * Adds a backdrop-blur background once the user scrolls.
 */
import { useTranslations, getLangFromUrl, localizePath } from '@i18n/utils';
import Logo from '@components/Logo.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { key: 'nav.home' as const, href: '/' },
  { key: 'nav.about' as const, href: '/about' },
  { key: 'nav.services' as const, href: '/services' },
  { key: 'nav.portfolio' as const, href: '/portfolio' },
  { key: 'nav.pricing' as const, href: '/pricing' },
  { key: 'nav.blog' as const, href: '/blog' },
  { key: 'nav.contact' as const, href: '/contact' },
];

const currentPath = Astro.url.pathname.replace(`/${lang}`, '') || '/';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a
      href={localizePath('/', lang)}
      class="flex items-center gap-2 text-white transition-opacity hover:opacity-80"
      aria-label="GlimoLab home"
    >
      <Logo variant="header" />
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden items-center gap-1 lg:flex">
      {navLinks.map((link) => {
        const isActive =
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={localizePath(link.href, lang)}
              class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
                isActive
                  ? 'text-white'
                  : 'text-text-muted hover:text-white'
              }`}
            >
              {t(link.key)}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Right cluster: language switcher + CTA -->
    <div class="flex items-center gap-3">
      <!-- Current language indicator -->
      <div class="relative hidden sm:block" id="lang-switcher">
        <button
          type="button"
          class="flex items-center gap-1 rounded-lg border border-dark-border px-2.5 py-2 text-sm text-text-light cursor-default"
          aria-label="Current language: English"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
          <span class="uppercase">{lang}</span>
        </button>

      </div>

      <!-- CTA button -->
      <a
        href={localizePath('/contact', lang)}
        class="hidden rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90 hover:shadow-lg sm:inline-block"
      >
        {t('cta.getStarted')}
      </a>

      <!-- Mobile hamburger -->
      <button
        type="button"
        id="menu-toggle"
        class="flex h-10 w-10 items-center justify-center rounded-lg text-text-light transition-colors hover:bg-dark-surface lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-dark-border bg-dark-bg/95 backdrop-blur-lg lg:hidden"
  >
    <ul class="space-y-1 px-4 py-4">
      {navLinks.map((link) => {
        const isActive =
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={localizePath(link.href, lang)}
              class={`block rounded-lg px-4 py-2.5 text-base font-medium transition-colors ${
                isActive ? 'bg-dark-surface text-white' : 'text-text-muted hover:bg-dark-surface hover:text-white'
              }`}
            >
              {t(link.key)}
            </a>
          </li>
        );
      })}
      <li class="pt-3">
        <a
          href={localizePath('/contact', lang)}
          class="block rounded-lg bg-primary px-5 py-3 text-center text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90"
        >
          {t('cta.getStarted')}
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-20"></div>

<script>
  // --- Scroll: toggle backdrop blur on the header ---
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    const scrolled = window.scrollY > 8;
    header.setAttribute('data-scrolled', String(scrolled));
    if (scrolled) {
      header.classList.add('bg-dark-bg/80', 'backdrop-blur-lg', 'border-b', 'border-dark-border', 'shadow-card');
    } else {
      header.classList.remove('bg-dark-bg/80', 'backdrop-blur-lg', 'border-b', 'border-dark-border', 'shadow-card');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // --- Mobile menu toggle ---
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  menuToggle?.addEventListener('click', () => {
    const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
    menuToggle.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });


</script>
