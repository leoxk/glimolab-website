---
/**
 * GlimoLab Featured Work — 3 project cards with video thumbnail placeholders
 */
import { useTranslations, getLangFromUrl, localizePath } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    categoryKey: 'work.project1.category' as const,
    titleKey: 'work.project1.title' as const,
    clientKey: 'work.project1.client' as const,
  },
  {
    categoryKey: 'work.project2.category' as const,
    titleKey: 'work.project2.title' as const,
    clientKey: 'work.project2.client' as const,
  },
  {
    categoryKey: 'work.project3.category' as const,
    titleKey: 'work.project3.title' as const,
    clientKey: 'work.project3.client' as const,
  },
];
---

<section class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section title -->
    <div class="animate-on-scroll text-center">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {t('work.sectionTitle')}
      </h2>
    </div>

    <!-- Project cards -->
    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {projects.map((project, i) => (
        <article class={`animate-on-scroll stagger-${i + 1} group cursor-pointer overflow-hidden rounded-2xl border border-dark-border bg-dark-surface transition-all duration-300 hover:-translate-y-1 hover:shadow-glow`}>
          <!-- Thumbnail placeholder -->
          <div class="relative aspect-video overflow-hidden bg-dark-bg">
            <!-- Placeholder gradient background -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-dark-bg to-accent/10"></div>
            <!-- Grid pattern overlay -->
            <div class="bg-grid absolute inset-0 opacity-30"></div>
            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="flex h-14 w-14 items-center justify-center rounded-full bg-dark-bg/60 text-white backdrop-blur-sm ring-1 ring-white/10 transition-transform group-hover:scale-110">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
            </div>
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-primary/0 transition-colors duration-300 group-hover:bg-primary/10"></div>
          </div>
          <!-- Card content -->
          <div class="p-6">
            <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {t(project.categoryKey)}
            </span>
            <h3 class="mt-3 font-heading text-lg font-semibold text-white transition-colors group-hover:text-primary">
              {t(project.titleKey)}
            </h3>
            <p class="mt-1.5 text-sm text-text-muted">
              {t(project.clientKey)}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- View all link -->
    <div class="animate-on-scroll mt-12 text-center">
      <a
        href={localizePath('/portfolio', lang)}
        class="group inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-accent"
      >
        {t('work.viewAll')}
        <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </div>
</section>
