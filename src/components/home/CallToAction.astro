---
/**
 * GlimoLab CTA — bottom call to action with grid node decoration
 */
import { useTranslations, getLangFromUrl, localizePath } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden py-24 sm:py-32">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-dark via-dark-bg to-dark-bg"></div>

  <!-- Grid node decoration -->
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full opacity-20"
    viewBox="0 0 1200 400"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <!-- Nodes row 1 -->
    <circle cx="100" cy="80" r="2" fill="#0066FF" class="hero-node" />
    <circle cx="300" cy="60" r="2.5" fill="#00BCD4" class="hero-node" />
    <circle cx="500" cy="100" r="2" fill="#0066FF" class="hero-node" />
    <circle cx="700" cy="70" r="3" fill="#00BCD4" class="hero-node" />
    <circle cx="900" cy="90" r="2" fill="#0066FF" class="hero-node" />
    <circle cx="1100" cy="75" r="2.5" fill="#00BCD4" class="hero-node" />
    <!-- Nodes row 2 -->
    <circle cx="150" cy="200" r="2" fill="#00BCD4" class="hero-node" />
    <circle cx="400" cy="250" r="3" fill="#0066FF" class="hero-node" />
    <circle cx="600" cy="180" r="2.5" fill="#00BCD4" class="hero-node" />
    <circle cx="800" cy="220" r="2" fill="#0066FF" class="hero-node" />
    <circle cx="1050" cy="190" r="3" fill="#00BCD4" class="hero-node" />
    <!-- Nodes row 3 -->
    <circle cx="200" cy="350" r="2.5" fill="#0066FF" class="hero-node" />
    <circle cx="500" cy="320" r="2" fill="#00BCD4" class="hero-node" />
    <circle cx="750" cy="370" r="3" fill="#0066FF" class="hero-node" />
    <circle cx="1000" cy="340" r="2" fill="#00BCD4" class="hero-node" />
    <!-- Connection lines -->
    <line x1="100" y1="80" x2="300" y2="60" stroke="#0066FF" stroke-width="0.8" class="hero-node-line" />
    <line x1="300" y1="60" x2="500" y2="100" stroke="#00BCD4" stroke-width="0.8" class="hero-node-line" />
    <line x1="500" y1="100" x2="700" y2="70" stroke="#0066FF" stroke-width="0.8" class="hero-node-line" />
    <line x1="700" y1="70" x2="900" y2="90" stroke="#00BCD4" stroke-width="0.8" class="hero-node-line" />
    <line x1="900" y1="90" x2="1100" y2="75" stroke="#0066FF" stroke-width="0.8" class="hero-node-line" />
    <line x1="150" y1="200" x2="400" y2="250" stroke="#00BCD4" stroke-width="0.8" class="hero-node-line" />
    <line x1="400" y1="250" x2="600" y2="180" stroke="#0066FF" stroke-width="0.8" class="hero-node-line" />
    <line x1="600" y1="180" x2="800" y2="220" stroke="#00BCD4" stroke-width="0.8" class="hero-node-line" />
    <line x1="800" y1="220" x2="1050" y2="190" stroke="#0066FF" stroke-width="0.8" class="hero-node-line" />
    <line x1="100" y1="80" x2="150" y2="200" stroke="#0066FF" stroke-width="0.5" class="hero-node-line" />
    <line x1="300" y1="60" x2="400" y2="250" stroke="#00BCD4" stroke-width="0.5" class="hero-node-line" />
    <line x1="700" y1="70" x2="600" y2="180" stroke="#0066FF" stroke-width="0.5" class="hero-node-line" />
    <line x1="900" y1="90" x2="800" y2="220" stroke="#00BCD4" stroke-width="0.5" class="hero-node-line" />
  </svg>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {t('cta.sectionTitle')}
      </h2>
      <p class="mt-4 text-lg text-text-muted sm:text-xl">
        {t('cta.sectionSubtitle')}
      </p>
    </div>

    <!-- CTA Button -->
    <div class="animate-on-scroll stagger-2 mt-10">
      <a
        href={localizePath('/contact', lang)}
        class="group inline-flex items-center gap-2 rounded-xl bg-primary px-10 py-4 text-lg font-semibold text-white shadow-glow transition-all hover:bg-primary/90 hover:shadow-[0_0_60px_-8px_rgba(0,102,255,0.6)]"
      >
        {t('cta.startProject')}
        <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>

    <!-- Contact info -->
    <div class="animate-on-scroll stagger-3 mt-8 flex flex-col items-center justify-center gap-4 text-sm text-text-muted sm:flex-row sm:gap-8">
      <a href="mailto:contact@glimolab.com" class="flex items-center gap-2 transition-colors hover:text-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-10 5L2 7" />
        </svg>
        contact@glimolab.com
      </a>
      <a href="https://wa.me/85296968865" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 transition-colors hover:text-accent">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
        </svg>
        +852 96968865
      </a>
    </div>
  </div>
</section>
