---
/**
 * GlimoLab Testimonials — 3 client testimonial cards with glass morphism
 */
import { useTranslations, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const testimonials = [
  {
    quoteKey: 'testimonials.quote1' as const,
    nameKey: 'testimonials.name1' as const,
    roleKey: 'testimonials.role1' as const,
    companyKey: 'testimonials.company1' as const,
  },
  {
    quoteKey: 'testimonials.quote2' as const,
    nameKey: 'testimonials.name2' as const,
    roleKey: 'testimonials.role2' as const,
    companyKey: 'testimonials.company2' as const,
  },
  {
    quoteKey: 'testimonials.quote3' as const,
    nameKey: 'testimonials.name3' as const,
    roleKey: 'testimonials.role3' as const,
    companyKey: 'testimonials.company3' as const,
  },
];
---

<section class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section title -->
    <div class="animate-on-scroll text-center">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {t('testimonials.sectionTitle')}
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {testimonials.map((item, i) => (
        <div class={`animate-on-scroll stagger-${i + 1} glass group relative rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1`}>
          <!-- Decorative quote mark -->
          <div class="animate-float absolute -top-1 right-6 text-6xl leading-none text-primary/15 select-none" aria-hidden="true">
            &ldquo;
          </div>
          <!-- Quote text -->
          <p class="relative text-base leading-relaxed text-text-light">
            {t(item.quoteKey)}
          </p>
          <!-- Author -->
          <div class="mt-6 flex items-center gap-4">
            <!-- Avatar placeholder -->
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 ring-1 ring-primary/20">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">{t(item.nameKey)}</p>
              <p class="text-xs text-text-muted">{t(item.roleKey)}, {t(item.companyKey)}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
