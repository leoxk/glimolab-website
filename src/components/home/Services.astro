---
/**
 * GlimoLab Services — 4 service cards with glass morphism
 */
import { useTranslations, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    iconPath: 'M15 10l4.553-2.276A1 1 0 0 1 21 8.618v6.764a1 1 0 0 1-1.447.894L15 14M5 18h8a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z',
    titleKey: 'services.aiVideo.title' as const,
    descKey: 'services.aiVideo.desc' as const,
  },
  {
    iconPath: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-8 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z',
    titleKey: 'services.ecommerce.title' as const,
    descKey: 'services.ecommerce.desc' as const,
  },
  {
    iconPath: 'M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 0 1 6.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129',
    titleKey: 'services.localization.title' as const,
    descKey: 'services.localization.desc' as const,
  },
  {
    iconPath: 'M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 1 1 0-2.684m0 2.684 6.632 3.316m-6.632-6 6.632-3.316m0 0a3 3 0 1 0 5.367-2.684 3 3 0 0 0-5.367 2.684zm0 9.316a3 3 0 1 0 5.368 2.684 3 3 0 0 0-5.368-2.684z',
    titleKey: 'services.social.title' as const,
    descKey: 'services.social.desc' as const,
  },
];
---

<section class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section title -->
    <div class="animate-on-scroll text-center">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {t('services.sectionTitle')}
      </h2>
    </div>

    <!-- Service cards grid -->
    <div class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-8">
      {services.map((service, i) => (
        <div class={`animate-on-scroll stagger-${i + 1} glass glow-border group rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-glow`}>
          <!-- Icon -->
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-inset ring-primary/20 transition-colors group-hover:bg-primary/20">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={service.iconPath} />
            </svg>
          </div>
          <!-- Content -->
          <h3 class="font-heading text-xl font-semibold text-white transition-colors group-hover:text-gradient">
            {t(service.titleKey)}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-text-muted">
            {t(service.descKey)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
