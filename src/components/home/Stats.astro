---
/**
 * GlimoLab Stats — key metrics with gradient numbers
 */
import { useTranslations, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { value: '85%', labelKey: 'stats.costReduction' as const },
  { value: '24h', labelKey: 'stats.turnaround' as const },
  { value: '30+', labelKey: 'stats.languages' as const },
  { value: '500+', labelKey: 'stats.videosMonthly' as const },
];
---

<section class="relative border-y border-dark-border py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-12">
      {stats.map((stat, i) => (
        <div class={`animate-on-scroll stagger-${i + 1} text-center`}>
          <div class="text-gradient stat-glow font-heading text-4xl font-bold sm:text-5xl lg:text-6xl">
            {stat.value}
          </div>
          <p class="mt-3 text-sm text-text-muted sm:text-base">
            {t(stat.labelKey)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
