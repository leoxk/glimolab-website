---
/**
 * GlimoLab How It Works — 4-step process with animated connector lines
 */
import { useTranslations, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  {
    num: '01',
    iconPath: 'M11 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-5m-1.414-9.414a2 2 0 1 1 2.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
    titleKey: 'howItWorks.step1.title' as const,
    descKey: 'howItWorks.step1.desc' as const,
  },
  {
    num: '02',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
    titleKey: 'howItWorks.step2.title' as const,
    descKey: 'howItWorks.step2.desc' as const,
  },
  {
    num: '03',
    iconPath: 'M4 4v5h.582m15.356 2A8.001 8.001 0 0 0 4.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 0 1-15.357-2m15.357 2H15',
    titleKey: 'howItWorks.step3.title' as const,
    descKey: 'howItWorks.step3.desc' as const,
  },
  {
    num: '04',
    iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z',
    titleKey: 'howItWorks.step4.title' as const,
    descKey: 'howItWorks.step4.desc' as const,
  },
];
---

<section class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section title -->
    <div class="animate-on-scroll text-center">
      <h2 class="font-heading text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {t('howItWorks.sectionTitle')}
      </h2>
    </div>

    <!-- Process steps -->
    <div class="relative mt-16">
      <!-- Desktop: horizontal layout with connecting lines -->
      <div class="hidden md:grid md:grid-cols-4 md:gap-8">
        {steps.map((step, i) => (
          <div class={`animate-on-scroll stagger-${i + 1} relative text-center`}>
            <!-- Connector line (except last) -->
            {i < steps.length - 1 && (
              <div class="absolute right-0 top-8 hidden h-[2px] w-full translate-x-1/2 md:block">
                <div class="line-animated h-full w-full rounded-full"></div>
              </div>
            )}
            <!-- Step number + icon -->
            <div class="relative mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-dark-surface ring-1 ring-dark-border">
              <span class="text-gradient font-heading text-lg font-bold">{step.num}</span>
            </div>
            <!-- Icon below -->
            <div class="mt-5 flex justify-center">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={step.iconPath} />
                </svg>
              </div>
            </div>
            <h3 class="mt-4 font-heading text-lg font-semibold text-white">
              {t(step.titleKey)}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">
              {t(step.descKey)}
            </p>
          </div>
        ))}
      </div>

      <!-- Mobile: vertical layout -->
      <div class="space-y-8 md:hidden">
        {steps.map((step, i) => (
          <div class={`animate-on-scroll stagger-${i + 1} flex gap-5`}>
            <!-- Step indicator -->
            <div class="flex flex-col items-center">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-dark-surface ring-1 ring-dark-border">
                <span class="text-gradient font-heading text-sm font-bold">{step.num}</span>
              </div>
              {i < steps.length - 1 && (
                <div class="mt-2 h-full w-[2px] flex-1 rounded-full bg-dark-border">
                  <div class="line-animated h-8 w-full rounded-full"></div>
                </div>
              )}
            </div>
            <!-- Content -->
            <div class="pb-8">
              <h3 class="font-heading text-lg font-semibold text-white">
                {t(step.titleKey)}
              </h3>
              <p class="mt-1.5 text-sm leading-relaxed text-text-muted">
                {t(step.descKey)}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
