---
/**
 * GlimoLab Footer — 4-column layout
 * Company intro · Services · Resources · Contact
 * Social icons + copyright bar at the bottom
 */
import { useTranslations, getLangFromUrl, localizePath } from '@i18n/utils';
import Logo from '@components/Logo.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();

const serviceLinks = [
  { label: 'AI Video Production', href: '/services/ai-video-production' },
  { label: 'E-commerce Content', href: '/services/ecommerce-content' },
  { label: 'Multilingual Localization', href: '/services/multilingual-localization' },
];

const resourceLinks = [
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Case Studies', href: '/portfolio' },
];

const socials = [
  {
    name: 'TikTok',
    href: 'https://tiktok.com/@glimolab',
    icon: 'M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64c.298 0 .593.045.878.134V9.4a6.33 6.33 0 0 0-.878-.063A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1.04-.07z',
  },
  {
    name: 'Facebook',
    href: 'https://facebook.com/glimolab',
    icon: 'M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.414c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.49 0-1.956.93-1.956 1.887v2.263h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z',
  },
  {
    name: 'Instagram',
    href: 'https://instagram.com/glimolab',
    icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z',
  },
];
---

<footer class="border-t border-dark-border bg-dark-bg">
  <!-- Main grid -->
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Company intro -->
      <div class="lg:pr-8">
        <a href={localizePath('/', lang)} class="inline-flex items-center text-white transition-opacity hover:opacity-80" aria-label="GlimoLab home">
          <Logo variant="footer" />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-text-muted">
          {t('footer.aboutText')}
        </p>
        <!-- Social icons -->
        <div class="mt-6 flex gap-3">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-lg border border-dark-border text-text-muted transition-all hover:border-primary hover:text-primary"
              aria-label={social.name}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-white">
          {t('footer.servicesTitle')}
        </h3>
        <ul class="mt-4 space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a
                href={localizePath(link.href, lang)}
                class="text-sm text-text-muted transition-colors hover:text-primary"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Resources -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-white">
          {t('footer.resourcesTitle')}
        </h3>
        <ul class="mt-4 space-y-3">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={localizePath(link.href, lang)}
                class="text-sm text-text-muted transition-colors hover:text-primary"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-white">
          {t('footer.contactTitle')}
        </h3>
        <ul class="mt-4 space-y-3 text-sm text-text-muted">
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m22 7-10 5L2 7" />
            </svg>
            <a href="mailto:contact@glimolab.com" class="transition-colors hover:text-primary">contact@glimolab.com</a>
          </li>
          <li class="flex items-start gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span>Manila · Jakarta · Remote</span>
          </li>
        </ul>
        <a
          href={localizePath('/contact', lang)}
          class="mt-5 inline-block rounded-lg bg-primary/10 px-5 py-2.5 text-sm font-semibold text-primary ring-1 ring-inset ring-primary/30 transition-all hover:bg-primary/20"
        >
          {t('cta.getStarted')}
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-dark-border">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row sm:px-6 lg:px-8">
      <p class="text-xs text-text-muted">
        © {year} GlimoLab. {t('footer.rights')}
      </p>
      <div class="flex gap-6">
        <a href={localizePath('/privacy', lang)} class="text-xs text-text-muted transition-colors hover:text-primary">
          {t('footer.privacy')}
        </a>
        <a href={localizePath('/terms', lang)} class="text-xs text-text-muted transition-colors hover:text-primary">
          {t('footer.terms')}
        </a>
      </div>
    </div>
  </div>
</footer>
