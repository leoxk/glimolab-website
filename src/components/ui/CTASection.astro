---
/**
 * CTASection — call-to-action banner with gradient glow
 * Reusable closing section for all pages.
 */
import { useTranslations, getLangFromUrl, localizePath } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = 'Ready to Create Something Extraordinary?',
  description = "Let's discuss how GlimoLab can transform your video content strategy with AI-powered production.",
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props;

const pLabel = primaryLabel ?? t('cta.getStarted');
const pHref = primaryHref ?? '/contact';
const sLabel = secondaryLabel ?? t('hero.exploreWork');
const sHref = secondaryHref ?? '/portfolio';
---

<section class="relative overflow-hidden py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="glass-card relative overflow-hidden px-8 py-16 text-center sm:px-16" data-reveal>
      <!-- Radial glow background -->
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(circle at 50% 0%, rgba(0,102,255,0.15) 0%, transparent 70%);"
      >
      </div>

      <div class="relative">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {title}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-text-muted">
          {description}
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href={localizePath(pHref, lang)}
            class="w-full rounded-lg bg-primary px-8 py-3.5 text-center text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90 hover:shadow-lg sm:w-auto"
          >
            {pLabel}
          </a>
          <a
            href={localizePath(sHref, lang)}
            class="w-full rounded-lg border border-dark-border px-8 py-3.5 text-center text-sm font-semibold text-text-light transition-all hover:border-primary hover:text-white sm:w-auto"
          >
            {sLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
