---
/**
 * PortfolioCard — case study thumbnail card with hover effects
 * Used in the portfolio listing grid. Links to the detail page.
 */
import { localizePath, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);

interface Props {
  title: string;
  description: string;
  category: string;
  client?: string;
  thumbnail?: string;
  slug: string;
}

const { title, description, category, client, thumbnail, slug } = Astro.props;

const categoryLabels: Record<string, string> = {
  ecommerce: 'E-commerce',
  brand: 'Brand',
  cinematic: 'Cinematic',
  automotive: 'Automotive',
  social: 'Social Media',
};
const label = categoryLabels[category] ?? category;
---

<a href={localizePath(`/portfolio/${slug}`, lang)} class="group block" data-reveal data-category={category}>
  <div class="glass-card glass-card-hover overflow-hidden">
    <div class="relative aspect-video overflow-hidden">
      {thumbnail ? (
        <img
          src={thumbnail}
          alt=""
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div
          class="flex h-full w-full items-center justify-center transition-transform duration-500 group-hover:scale-105"
          style="background: linear-gradient(135deg, rgba(0,102,255,0.15) 0%, rgba(0,188,212,0.08) 100%);"
        >
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/40" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <polygon points="10 8 16 12 10 16 10 8" fill="currentColor" />
          </svg>
        </div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-dark-bg/70 via-transparent to-transparent"></div>
      <span class="absolute left-3 top-3 rounded-md bg-primary/90 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur">
        {label}
      </span>
      <span class="absolute bottom-3 right-3 flex h-10 w-10 items-center justify-center rounded-full bg-dark-bg/70 text-white ring-1 ring-white/15 backdrop-blur transition-transform group-hover:scale-110">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
      </span>
    </div>

    <div class="p-6">
      <h3 class="text-lg font-bold text-white transition-colors group-hover:text-primary">
        {title}
      </h3>
      {client && <p class="mt-1 text-sm font-medium text-accent">{client}</p>}
      <p class="mt-2 text-sm leading-relaxed text-text-muted line-clamp-2">{description}</p>

      <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
        View Case Study
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </span>
    </div>
  </div>
</a>
