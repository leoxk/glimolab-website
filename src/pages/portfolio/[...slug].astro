---
/**
 * GlimoLab Portfolio Detail Page
 * Dynamic route — renders a single case study from the portfolio collection.
 * Layout: Hero (video placeholder) → MDX content → Results → Related cases
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/ui/CTASection.astro';
import PortfolioCard from '@components/portfolio/PortfolioCard.astro';
import { getCollection, render } from 'astro:content';
import { localizePath, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);

// --- Generate static paths from portfolio collection ---
export async function getStaticPaths() {
  const portfolio = await getCollection('portfolio');
  return portfolio.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// --- Fetch related cases (same category, excluding current) ---
const allPortfolio = await getCollection('portfolio');
const related = allPortfolio
  .filter((e) => e.id !== entry.id && e.data.category === entry.data.category)
  .slice(0, 3);

// If not enough same-category, fill with others
if (related.length < 3) {
  const others = allPortfolio
    .filter((e) => e.id !== entry.id && e.data.category !== entry.data.category)
    .slice(0, 3 - related.length);
  related.push(...others);
}

// --- Data for display ---
const categoryLabels: Record<string, string> = {
  ecommerce: 'E-commerce',
  brand: 'Brand',
  education: 'Education',
  social: 'Social Media',
};
const categoryLabel = categoryLabels[entry.data.category] ?? entry.data.category;
const results = entry.data.results;
const formattedDate = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Result stats array (filter out undefined)
const resultStats = [
  { label: 'Total Views', value: results?.views, icon: '👁' },
  { label: 'Conversion Lift', value: results?.conversion, icon: '📈' },
  { label: 'Cost Saving', value: results?.cost_saving, icon: '💰' },
].filter((s) => s.value);
---

<BaseLayout
  title={`${entry.data.title} — GlimoLab Portfolio`}
  description={entry.data.description}
>
  <!-- ============ Hero (video placeholder) ============ -->
  <section class="relative overflow-hidden">
    <div class="bg-grid pointer-events-none absolute inset-0"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(0,102,255,0.15) 0%, transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:py-24">
      <!-- Breadcrumb -->
      <a href={localizePath('/portfolio', lang)} class="inline-flex items-center gap-1.5 text-sm text-text-muted transition-colors hover:text-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Back to Portfolio
      </a>

      <!-- Meta -->
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span class="rounded-md bg-primary/90 px-2.5 py-1 text-xs font-semibold text-white">{categoryLabel}</span>
        {entry.data.client && (
          <span class="text-sm text-text-muted">{entry.data.client}</span>
        )}
        <span class="text-sm text-text-muted">·</span>
        <span class="text-sm text-text-muted">{formattedDate}</span>
      </div>

      <!-- Title -->
      <h1 class="animate-fade-in-up mt-4 text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl lg:text-5xl">
        {entry.data.title}
      </h1>
      <p class="animate-fade-in-up mt-4 max-w-3xl text-lg leading-relaxed text-text-muted" style="animation-delay: 0.1s;">
        {entry.data.description}
      </p>

      <!-- Video placeholder -->
      <div class="mt-8 overflow-hidden rounded-2xl border border-dark-border" data-reveal>
        <div class="relative aspect-video w-full">
          <div
            class="flex h-full w-full items-center justify-center"
            style="background: linear-gradient(135deg, rgba(0,102,255,0.1) 0%, rgba(0,188,212,0.05) 100%);"
          >
            <div class="flex flex-col items-center gap-3">
              <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary/20 ring-1 ring-inset ring-primary/40 backdrop-blur transition-transform hover:scale-110">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-white" aria-hidden="true">
                  <polygon points="6 4 20 12 6 20 6 4" />
                </svg>
              </div>
              <p class="text-sm text-text-muted">Video preview coming soon</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MDX Content ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="prose-content space-y-6 text-text-muted">
        <Content />
      </div>
    </div>
  </section>

  <!-- ============ Results Data ============ -->
  {resultStats.length > 0 && (
    <section class="border-t border-dark-border py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center" data-reveal>
          <p class="font-heading text-sm font-semibold uppercase tracking-widest text-primary">Impact</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white">Results That Matter</h2>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {resultStats.map((stat) => (
            <div class="glass-card glass-card-hover p-8 text-center" data-reveal>
              <div class="text-3xl">{stat.icon}</div>
              <p class="mt-3 text-3xl font-bold text-gradient">{stat.value}</p>
              <p class="mt-1 text-sm font-medium text-text-muted">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============ Related Cases ============ -->
  {related.length > 0 && (
    <section class="border-t border-dark-border py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center" data-reveal>
          <p class="font-heading text-sm font-semibold uppercase tracking-widest text-primary">Keep Exploring</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white">Related Cases</h2>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {related.map((rel) => (
            <PortfolioCard
              title={rel.data.title}
              description={rel.data.description}
              category={rel.data.category}
              client={rel.data.client}
              slug={rel.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============ CTA ============ -->
  <CTASection
    title="Inspired by What You See?"
    description="Let's create a success story of your own with GlimoLab's AI-powered production."
    primaryLabel="Start a Project"
    secondaryLabel="View All Work"
  />
</BaseLayout>

<style is:global>
  /* Prose styling for MDX content on dark background */
  .prose-content h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-white);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-content p {
    line-height: 1.75;
    color: var(--color-text-muted);
  }
  .prose-content ul,
  .prose-content ol {
    line-height: 1.75;
    color: var(--color-text-muted);
    padding-left: 1.5rem;
  }
  .prose-content li {
    margin-top: 0.5rem;
  }
  .prose-content strong {
    color: var(--color-text-light);
    font-weight: 600;
  }
  .prose-content a {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
