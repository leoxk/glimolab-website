---
/**
 * GlimoLab Pricing Page
 * Public single-project and monthly package pricing for AI-assisted commercial video.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl, localizePath, type UIKey } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projectPlans = [
  {
    name: 'Studio',
    standardPrice: '$720',
    launchPrice: '$360',
    reference: 'PHP 22K / IDR 6.4M',
    discountTag: 'First Video 50% OFF',
    highlighted: false,
    primarySpecs: [
      ['pricing.spec.resolution', '720P/1080P vertical'],
      ['pricing.spec.length', '15-30 sec'],
    ],
    decisionPoints: [
      ['pricing.spec.localization', 'pricing.localization.englishOnly'],
      ['pricing.spec.digitalHuman', 'pricing.digitalHuman.notIncluded'],
    ],
  },
  {
    name: 'Signature',
    standardPrice: '$1,280',
    launchPrice: '$640',
    reference: 'PHP 39K / IDR 11.5M',
    discountTag: 'First Video 50% OFF',
    highlighted: true,
    badge: 'pricing.badgePopular',
    primarySpecs: [
      ['pricing.spec.resolution', '1080P/2K horizontal'],
      ['pricing.spec.length', '30-90 sec'],
    ],
    decisionPoints: [
      ['pricing.spec.localization', 'pricing.localization.included'],
      ['pricing.spec.digitalHuman', 'pricing.digitalHuman.included'],
    ],
  },
  {
    name: 'Cinematic',
    launchPrice: 'Contact Sales',
    reference: 'Custom 4K project quote',
    contactOnly: true,
    highlighted: false,
    primarySpecs: [
      ['pricing.spec.resolution', '4K cinematic'],
      ['pricing.spec.length', '60-180 sec'],
    ],
    decisionPoints: [
      ['pricing.spec.localization', 'pricing.localization.included'],
      ['pricing.spec.digitalHuman', 'pricing.digitalHuman.included'],
    ],
  },
];

const monthlyPackages = [
  {
    name: 'Starter',
    monthlyPrice: '$1,800/mo',
    reference: 'PHP 110K / IDR 32.2M',
    primarySpecs: [
      ['pricing.spec.resolution', '720P/1080P vertical'],
      ['pricing.spec.length', '15-30 sec each'],
      ['pricing.spec.quantity', '4 videos/mo'],
    ],
    decisionPoints: [
      ['pricing.spec.localization', 'pricing.localization.englishOnly'],
      ['pricing.spec.digitalHuman', 'pricing.digitalHuman.monthlyAddOn'],
    ],
  },
  {
    name: 'Premium',
    monthlyPrice: '$4,800/mo',
    reference: 'PHP 293K / IDR 85.9M',
    highlighted: true,
    primarySpecs: [
      ['pricing.spec.resolution', '1080P/2K horizontal'],
      ['pricing.spec.length', '30-90 sec each'],
      ['pricing.spec.quantity', '6 videos/mo'],
    ],
    decisionPoints: [
      ['pricing.spec.localization', 'pricing.localization.included'],
      ['pricing.spec.digitalHuman', 'pricing.digitalHuman.monthlyContinuity'],
    ],
  },
  {
    name: 'Flagship',
    monthlyPrice: 'Contact Sales',
    reference: 'Custom 4K monthly quote',
    contactOnly: true,
    primarySpecs: [
      ['pricing.spec.resolution', '4K cinematic'],
      ['pricing.spec.length', '60-180 sec each'],
      ['pricing.spec.quantity', '8 videos/mo'],
    ],
    decisionPoints: [
      ['pricing.spec.localization', 'pricing.localization.included'],
      ['pricing.spec.digitalHuman', 'pricing.digitalHuman.monthlyCustom'],
    ],
  },
];

const faqs = [
  { q: 'faq.q1', a: 'faq.a1' },
  { q: 'faq.q2', a: 'faq.a2' },
  { q: 'faq.q3', a: 'faq.a3' },
  { q: 'faq.q4', a: 'faq.a4' },
  { q: 'faq.q5', a: 'faq.a5' },
  { q: 'faq.q6', a: 'faq.a6' },
];
---

<BaseLayout
  title="Pricing — GlimoLab"
  description="Premium AI-assisted commercial video production pricing for vertical social videos, horizontal corporate films, and 4K cinematic TVC work."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <img
      src="/assets/banner-pricing.png"
      alt=""
      class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-45"
      aria-hidden="true"
    />
    <div class="pointer-events-none absolute inset-0 bg-dark-bg/70"></div>
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-60"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(0,102,255,0.12) 0%, transparent 70%);"
    ></div>

    <div class="relative mx-auto max-w-4xl px-4 py-24 text-center sm:px-6 lg:py-32">
      <p class="font-heading text-sm font-semibold uppercase tracking-widest text-primary">
        {t('pricing.badge')}
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl">
        {t('pricing.title')}
      </h1>
      <p class="mt-4 text-lg text-text-muted">
        {t('pricing.subtitle')}
      </p>
      <p class="mt-5 inline-flex rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-medium text-accent">
        {t('pricing.launchNote')}
      </p>
    </div>
  </section>

  <!-- Single Project Pricing -->
  <section class="relative -mt-8 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="font-heading text-3xl font-bold text-white">
          {t('pricing.singleTitle')}
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-text-muted">
          {t('pricing.singleSubtitle')}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {projectPlans.map((plan) => (
          <div
            class:list={[
              'relative flex flex-col rounded-2xl border p-8 transition-all',
              plan.highlighted
                ? 'z-10 scale-[1.02] border-primary bg-dark-surface shadow-glow md:scale-105'
                : 'border-dark-border bg-dark-surface/50 hover:border-primary/50',
            ]}
          >
            {plan.badge && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-bold uppercase tracking-wider text-white">
                {t(plan.badge as UIKey)}
              </span>
            )}
            {plan.discountTag && (
              <span class="absolute right-4 top-4 rounded-full bg-red-600 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white shadow-lg shadow-red-600/25">
                {plan.discountTag}
              </span>
            )}
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-heading text-xl font-semibold text-white">{plan.name}</h3>
            </div>
            <div class="mt-6">
              <p class="text-xs font-semibold uppercase tracking-widest text-text-muted">
                {plan.contactOnly ? 'Custom Quote' : t('pricing.launchPrice')}
              </p>
              <div class="mt-2 flex items-end gap-3">
                {plan.contactOnly ? (
                  <a
                    href={localizePath('/contact', lang)}
                    class="inline-flex rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90"
                  >
                    Contact Sales
                  </a>
                ) : (
                  <>
                    <span class="text-4xl font-bold text-white">{plan.launchPrice}</span>
                    {plan.standardPrice && (
                      <span class="pb-1 text-sm text-text-muted line-through">{plan.standardPrice}</span>
                    )}
                  </>
                )}
              </div>
              <p class="mt-2 text-xs text-text-muted">{plan.reference}</p>
            </div>
            <div class="mt-8 grid grid-cols-1 gap-3">
              {plan.primarySpecs.map(([label, value]) => (
                <div class="rounded-xl border border-primary/20 bg-primary/10 p-4">
                  <p class="text-xs font-medium text-text-muted">{t(label as UIKey)}</p>
                  <p class="mt-2 font-heading text-2xl font-bold text-white">{value}</p>
                </div>
              ))}
            </div>
            <div class="mt-6 flex-1 space-y-3 border-t border-dark-border pt-5">
              {plan.decisionPoints.map(([label, value]) => (
                <div class="flex items-start justify-between gap-4 text-sm">
                  <span class="text-text-muted">{t(label as UIKey)}</span>
                  <span class="max-w-[58%] text-right font-semibold text-text-light">{t(value as UIKey)}</span>
                </div>
              ))}
            </div>
            {!plan.contactOnly && (
              <a
                href={localizePath('/contact', lang)}
                class:list={[
                  'mt-8 block rounded-lg py-3.5 text-center text-sm font-semibold transition-all',
                  plan.highlighted
                    ? 'bg-primary text-white shadow-glow hover:bg-primary/90'
                    : 'border border-dark-border text-text-light hover:border-primary hover:text-white',
                ]}
              >
                {t('pricing.requestQuote')}
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Monthly Packages -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="font-heading text-3xl font-bold text-white">
          {t('pricing.monthlyTitle')}
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-text-muted">
          {t('pricing.monthlySubtitle')}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {monthlyPackages.map((pkg) => (
          <div
            class:list={[
              'rounded-2xl border p-7 transition-all',
              pkg.highlighted
                ? 'border-primary bg-dark-surface shadow-glow'
                : 'border-dark-border bg-dark-surface/50 hover:border-primary/50',
            ]}
          >
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-heading text-lg font-semibold text-white">{pkg.name}</h3>
            </div>
            <div class="mt-5">
              {pkg.contactOnly ? (
                <a
                  href={localizePath('/contact', lang)}
                  class="inline-flex rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90"
                >
                  Contact Sales
                </a>
              ) : (
                <p class="text-3xl font-bold text-white">{pkg.monthlyPrice}</p>
              )}
              <p class="mt-2 text-xs text-text-muted">{pkg.reference}</p>
            </div>
            <div class="mt-7 grid grid-cols-1 gap-3">
              {pkg.primarySpecs.map(([label, value]) => (
                <div class:list={[
                  'rounded-xl border border-primary/20 bg-primary/10 p-4',
                  label === 'pricing.spec.quantity' ? 'border-primary/40 bg-primary/15' : '',
                ]}>
                  <p class="text-xs font-medium text-text-muted">{t(label as UIKey)}</p>
                  <p class="mt-2 font-heading text-2xl font-bold text-white">{value}</p>
                </div>
              ))}
            </div>
            <div class="mt-6 space-y-3 border-t border-dark-border pt-5">
              {pkg.decisionPoints.map(([label, value]) => (
                <div class="flex items-start justify-between gap-4 text-sm">
                  <span class="text-text-muted">{t(label as UIKey)}</span>
                  <span class="max-w-[58%] text-right font-semibold text-text-light">{t(value as UIKey)}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="border-t border-dark-border py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-heading text-3xl font-bold text-white">
        {t('pricing.faqTitle')}
      </h2>
      <p class="mt-3 text-center text-text-muted">
        {t('pricing.faqSubtitle')}
      </p>
      <div class="mt-12 space-y-4" id="faq-list">
        {faqs.map((faq) => (
          <div class="faq-item rounded-xl border border-dark-border bg-dark-surface/50">
            <button
              type="button"
              class="faq-toggle flex w-full items-center justify-between px-6 py-5 text-left"
              aria-expanded="false"
            >
              <span class="pr-4 font-medium text-text-light">{t(faq.q as UIKey)}</span>
              <svg class="faq-chevron h-5 w-5 shrink-0 text-text-muted transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-sm leading-relaxed text-text-muted">{t(faq.a as UIKey)}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="border-t border-dark-border py-24">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="font-heading text-3xl font-bold text-white">
        {t('pricing.bottomCtaTitle')}
      </h2>
      <p class="mt-4 text-text-muted">
        {t('pricing.bottomCtaSubtitle')}
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={localizePath('/contact', lang)}
          class="rounded-lg bg-primary px-8 py-3.5 text-sm font-semibold text-white shadow-glow transition-all hover:bg-primary/90 hover:shadow-lg"
        >
          {t('cta.contactUs')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const chevron = item?.querySelector('.faq-chevron');
      const expanded = btn.getAttribute('aria-expanded') === 'true';

      btn.setAttribute('aria-expanded', String(!expanded));

      if (content) {
        content.classList.toggle('hidden', expanded);
      }
      if (chevron) {
        chevron.classList.toggle('rotate-180', !expanded);
      }
    });
  });
</script>
