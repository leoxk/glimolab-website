---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Service — GlimoLab"
  description="GlimoLab terms of service for website use and project inquiries."
>
  <section class="relative overflow-hidden">
    <div class="bg-grid pointer-events-none absolute inset-0"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[420px] w-[720px] -translate-x-1/2 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(0,188,212,0.12) 0%, transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-3xl px-4 py-24 sm:px-6 lg:py-32">
      <p class="font-heading text-sm font-semibold uppercase tracking-widest text-accent">
        Legal
      </p>
      <h1 class="mt-5 text-4xl font-bold leading-tight text-white sm:text-5xl">
        Terms of Service
      </h1>
      <p class="mt-5 text-sm text-text-muted">Last updated: June 28, 2026</p>
    </div>
  </section>

  <section class="border-t border-dark-border py-16">
    <div class="mx-auto max-w-3xl space-y-10 px-4 text-text-muted sm:px-6">
      <div>
        <h2 class="text-xl font-bold text-white">Website Use</h2>
        <p class="mt-3 leading-relaxed">
          This website provides general information about GlimoLab services. Content on this site is
          provided for informational purposes and may be updated without notice.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-white">Project Engagements</h2>
        <p class="mt-3 leading-relaxed">
          Service scope, deliverables, timelines, pricing, revision terms, and usage rights are
          confirmed separately in a proposal, statement of work, invoice, or written agreement.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-white">Client Materials</h2>
        <p class="mt-3 leading-relaxed">
          You are responsible for ensuring that assets, product claims, trademarks, and other
          materials you provide can be used for the requested production work.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-bold text-white">Contact</h2>
        <p class="mt-3 leading-relaxed">
          For questions about these terms, contact{' '}
          <a href="mailto:contact@glimolab.com" class="text-primary hover:text-accent">contact@glimolab.com</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
