---
/**
 * GlimoLab Blog Detail Page
 * Renders a single blog post from the content collection
 * with meta info, body content, and related posts
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { useTranslations, getLangFromUrl, localizePath } from '@i18n/utils';
import { getCollection, render } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts: same tags, exclude current
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.tags.some((tag) => post.data.tags.includes(tag)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={`${post.data.title} — GlimoLab`}
  description={post.data.description}
  image={post.data.image}
>
  <article class="pb-24">
    <!-- Article Header -->
    <header class="relative overflow-hidden">
      <div class="bg-grid pointer-events-none absolute inset-0"></div>
      <div class="relative mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:py-28">
        <!-- Tags -->
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                {tag}
              </span>
            ))}
          </div>
        )}
        <!-- Title -->
        <h1 class="mt-4 font-heading text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
          {post.data.title}
        </h1>
        <!-- Meta -->
        <div class="mt-6 flex items-center gap-4 text-sm text-text-muted">
          <span>{post.data.author}</span>
          <span>·</span>
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
        </div>
      </div>
    </header>

    <!-- Article Body -->
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-heading prose-headings:text-white
        prose-p:text-text-muted prose-p:leading-relaxed
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white
        prose-code:text-accent prose-code:before:content-[''] prose-code:after:content-['']
        prose-pre:bg-dark-surface prose-pre:border prose-pre:border-dark-border
        prose-blockquote:border-primary prose-blockquote:text-text-muted
        prose-img:rounded-xl
        prose-hr:border-dark-border
      ">
        <Content />
      </div>
    </div>

    <!-- Back to Blog -->
    <div class="mx-auto mt-12 max-w-3xl px-4 sm:px-6">
      <a
        href={localizePath('/blog', lang)}
        class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-accent"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        {t('blog.backToBlog')}
      </a>
    </div>
  </article>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="border-t border-dark-border py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-2xl font-bold text-white">
          {t('blog.relatedPosts')}
        </h2>
        <div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-2">
          {relatedPosts.map((relPost) => (
            <a
              href={localizePath(`/blog/${relPost.id}`, lang)}
              class="group rounded-2xl border border-dark-border bg-dark-surface/50 p-6 transition-all hover:border-primary/50 hover:shadow-card"
            >
              <div class="flex items-center gap-3 text-xs text-text-muted">
                <time datetime={relPost.data.date.toISOString()}>
                  {formatDate(relPost.data.date)}
                </time>
                {relPost.data.tags.length > 0 && (
                  <>
                    <span>·</span>
                    <span class="text-primary">{relPost.data.tags[0]}</span>
                  </>
                )}
              </div>
              <h3 class="mt-2 font-heading text-lg font-semibold text-white transition-colors group-hover:text-primary">
                {relPost.data.title}
              </h3>
              <p class="mt-2 text-sm text-text-muted line-clamp-2">
                {relPost.data.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
