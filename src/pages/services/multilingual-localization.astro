---
/**
 * Service: Multilingual Localization
 * Hero → Features → Language Coverage → Process → CTA
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import CTASection from '@components/ui/CTASection.astro';
import { localizePath, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);

const features = [
  { title: 'AI Voice Cloning', description: 'Clone original speaker voices with natural intonation in any language — preserving brand consistency across markets.', icon: '🎙️' },
  { title: 'Cultural Adaptation', description: 'Beyond translation — we adapt idioms, humor, and cultural references for authentic local resonance.', icon: '🌍' },
  { title: 'Subtitle Generation', description: 'Automatic subtitle creation with precise timing, burned-in or soft subs, in any format you need.', icon: '💬' },
  { title: '10+ Languages', description: 'From English and Filipino to Bahasa Indonesia, Thai, Vietnamese, and more — we cover the region.', icon: '🌐' },
];

const languages = [
  'English', 'Filipino (Tagalog)', 'Bahasa Indonesia', 'Bahasa Melayu',
  'Thai', 'Vietnamese', 'Chinese (Mandarin)', 'Chinese (Cantonese)',
  'Japanese', 'Korean', 'Hindi', 'Bengali',
  'Tamil', 'Spanish', 'Portuguese', 'French',
  'German', 'Arabic', 'Russian', 'Turkish',
  'Italian', 'Dutch', 'Polish', 'Swedish',
  'Norwegian', 'Danish', 'Finnish', 'Czech',
  'Greek', 'Hebrew', 'Romanian', 'Hungarian',
];

const steps = [
  { step: '01', title: 'Source Analysis', description: 'We analyze the original video, transcribe dialogue, and identify cultural elements that need adaptation.' },
  { step: '02', title: 'Translation & Adaptation', description: 'Native-speaker linguists + AI create culturally-adapted scripts in each target language.' },
  { step: '03', title: 'AI Dubbing', description: 'Voice cloning technology generates natural-sounding dubbing that matches original timing and emotion.' },
  { step: '04', title: 'Subtitle & Delivery', description: 'Burned-in or soft subtitles added, with final QC and delivery in all requested formats.' },
];
---

<BaseLayout
  title="Multilingual Localization — GlimoLab Services"
  description="Reach audiences in 10+ languages with AI-powered dubbing, voice cloning, cultural adaptation, and automatic subtitle generation."
>
  <!-- ============ Hero ============ -->
  <section class="relative overflow-hidden">
    <div class="bg-grid pointer-events-none absolute inset-0"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(0,102,255,0.15) 0%, transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-4xl px-4 py-24 sm:px-6 lg:py-32">
      <a href={localizePath('/services', lang)} class="inline-flex items-center gap-1.5 text-sm text-text-muted transition-colors hover:text-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        All Services
      </a>

      <div class="animate-fade-in-up mt-6 inline-flex items-center gap-2 rounded-full border border-dark-border bg-dark-surface/50 px-4 py-1.5 text-xs font-medium text-accent backdrop-blur">
        Multilingual Localization
      </div>

      <h1 class="animate-fade-in-up mt-6 text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl" style="animation-delay: 0.1s;">
        Multilingual Localization
      </h1>

      <p class="animate-fade-in-up mt-6 max-w-2xl text-lg leading-relaxed text-text-muted" style="animation-delay: 0.2s;">
        Reach audiences in 10+ languages with AI-powered dubbing and subtitles. We go beyond translation to deliver culturally resonant content for every market.
      </p>
    </div>
  </section>

  <!-- ============ Features ============ -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Capabilities"
        title="What We Offer"
        subtitle="AI-powered localization that preserves your message while resonating with local audiences."
      />
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {features.map((feature) => (
          <div class="glass-card glass-card-hover flex gap-4 p-6" data-reveal>
            <div class="text-3xl shrink-0">{feature.icon}</div>
            <div>
              <h3 class="text-base font-bold text-white">{feature.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-text-muted">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Language Coverage ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Language Coverage"
        title="10+ Languages Supported"
        subtitle="From Southeast Asia to Europe and beyond — we help you speak your audience's language."
      />
      <div class="mt-12 glass-card p-8" data-reveal>
        <div class="flex flex-wrap gap-2">
          {languages.map((language) => (
            <span class="rounded-lg border border-dark-border bg-dark-surface/50 px-3 py-1.5 text-sm text-text-light transition-colors hover:border-primary hover:text-primary">
              {language}
            </span>
          ))}
          <span class="rounded-lg border border-dashed border-primary/40 bg-primary/5 px-3 py-1.5 text-sm font-medium text-primary">
            + more on request
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Process ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="How It Works"
        title="Localization Process"
        subtitle="A 4-step pipeline from source analysis to multi-language delivery."
      />
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {steps.map((step) => (
          <div class="glass-card glass-card-hover relative p-6" data-reveal>
            <span class="font-heading text-4xl font-bold text-primary/20">{step.step}</span>
            <h3 class="mt-2 text-base font-bold text-white">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <CTASection
    title="Ready to Go Global?"
    description="Expand your reach with AI-powered multilingual video localization."
    primaryLabel="Start a Project"
    secondaryLabel="See Examples"
  />
</BaseLayout>
