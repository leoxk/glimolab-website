---
/**
 * GlimoLab Services Overview Page
 * Hero → 3 service cards → CTA
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/ui/CTASection.astro';
import { localizePath, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);

const services = [
  {
    title: 'AI Video Production',
    description:
      'From product showcases to brand stories, we create professional videos using state-of-the-art AI generation, voice synthesis, and automated editing.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M10 9l5 3-5 3V9z" fill="currentColor"/></svg>`,
    features: ['Product demos', 'Brand commercials', 'Explainer videos', 'Social media ads'],
    href: '/services/ai-video-production',
    accent: 'primary',
  },
  {
    title: 'E-commerce Content',
    description:
      'Platform-optimized product videos for Shopee, TikTok Shop, and Lazada — designed to highlight key selling points, build trust, and improve purchase intent.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>`,
    features: ['Platform-specific formats', 'Selling-point visualization', 'Product trust and use-case demos', 'Multi-platform export'],
    href: '/services/ecommerce-content',
    accent: 'accent',
  },
  {
    title: 'Multilingual Localization',
    description:
      'Reach audiences in 10+ languages with AI-powered dubbing, voice cloning, cultural adaptation, and automatic subtitle generation.',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    features: ['AI voice cloning', 'Cultural adaptation', 'Subtitle generation', '10+ languages'],
    href: '/services/multilingual-localization',
    accent: 'primary',
  },
];

const capabilities = [
  {
    title: '1:1 Custom Digital Humans',
    description:
      'Create deeply customized AI presenters, brand characters, or executive avatars based on real people, with stable facial identity and styling across multiple videos.',
    label: 'Identity Consistency',
    value: 'High across every episode',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"/><path d="M4 21a8 8 0 0 1 16 0"/><path d="M17 8l2 2 3-4"/></svg>`,
    bullets: ['1:1 likeness planning from real-person references', 'Consistent face, wardrobe, and visual identity', 'Suitable for spokesperson series and recurring campaigns'],
  },
  {
    title: 'Cinematic Super-Resolution Video',
    description:
      'Deliver premium 4K super-resolution video with film-level polish for luxury launches, high-end exhibitions, large screens, and cinema-grade brand moments.',
    label: 'Output Quality',
    value: '4K cinematic finish',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 3v4M17 3v4M7 17v4M17 17v4M3 9h18M3 15h18"/></svg>`,
    bullets: ['4K lossless-style upscaling and finishing', 'Designed for exhibitions, cinema, and premium displays', 'Strict product detail, lighting, and scene consistency'],
  },
];

const productionTiers = [
  {
    name: 'Social Video',
    length: '15-30 sec',
    quality: '720P/1080P vertical',
    consistency: 'Fast-cut editing with light consistency control',
    asset: 'Public or lightweight presenter assets',
  },
  {
    name: 'Corporate Film',
    length: '30-90 sec',
    quality: '1080P/2K horizontal',
    consistency: 'Product and scene control for brand use',
    asset: 'Custom executive avatar or voice clone available',
  },
  {
    name: 'Cinematic / TVC',
    length: '60-180 sec',
    quality: '4K cinematic',
    consistency: 'High-control visual system for multi-shot accuracy',
    asset: 'Fully customized creative character or premium digital human',
  },
];
---

<BaseLayout
  title="Our Services — GlimoLab AI Video Production"
  description="AI video production, e-commerce content, and multilingual localization services tailored for brands across Southeast Asia."
>
  <!-- ============ Hero ============ -->
  <section class="relative overflow-hidden">
    <img
      src="/assets/banner-services.png"
      alt=""
      class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-45"
      aria-hidden="true"
    />
    <div class="pointer-events-none absolute inset-0 bg-dark-bg/70"></div>
    <div class="bg-grid pointer-events-none absolute inset-0 opacity-60"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(0,102,255,0.15) 0%, transparent 70%);"
    >
    </div>

    <div class="relative mx-auto flex max-w-4xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:py-32">
      <div class="animate-fade-in-up inline-flex items-center gap-2 rounded-full border border-dark-border bg-dark-surface/50 px-4 py-1.5 text-xs font-medium text-accent backdrop-blur">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
        </span>
        What We Do
      </div>

      <h1 class="animate-fade-in-up mt-8 text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl" style="animation-delay: 0.1s;">
        Our Services
      </h1>

      <p class="animate-fade-in-up mt-6 max-w-2xl text-lg leading-relaxed text-text-muted" style="animation-delay: 0.2s;">
        End-to-end AI-powered video production services — from concept to multi-platform delivery, optimized for Southeast Asian markets.
      </p>
    </div>
  </section>

  <!-- ============ Service Cards ============ -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a
            href={localizePath(service.href, lang)}
            class="group block"
            data-reveal
          >
            <div class="glass-card glass-card-hover flex h-full flex-col p-8">
              <!-- Icon -->
              <div
                class={`flex h-14 w-14 items-center justify-center rounded-xl ring-1 ring-inset ${
                  service.accent === 'primary'
                    ? 'bg-primary/10 text-primary ring-primary/30'
                    : 'bg-accent/10 text-accent ring-accent/30'
                }`}
                set:html={service.icon}
              >
              </div>

              <h3 class="mt-5 text-xl font-bold text-white transition-colors group-hover:text-primary">
                {service.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-text-muted">
                {service.description}
              </p>

              <!-- Feature list -->
              <ul class="mt-5 space-y-2">
                {service.features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-text-light">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={`shrink-0 ${service.accent === 'primary' ? 'text-primary' : 'text-accent'}`} aria-hidden="true">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <!-- Learn more link -->
              <span class="mt-auto pt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
                Learn More
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Advanced Capabilities ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Advanced Production Capabilities</p>
        <h2 class="mt-3 font-heading text-3xl font-bold text-white sm:text-4xl">
          Built for Brand Consistency and Premium Display
        </h2>
        <p class="mt-4 text-text-muted">
          Beyond standard AI video generation, GlimoLab supports custom identity assets and cinematic finishing for campaigns that need to look consistent, premium, and ready for high-value channels.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
        {capabilities.map((capability) => (
          <div class="glass-card p-8" data-reveal>
            <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-inset ring-primary/30" set:html={capability.icon}></div>
              <div class="min-w-0">
                <h3 class="text-2xl font-bold text-white">{capability.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-text-muted">{capability.description}</p>
                <div class="mt-5 rounded-lg border border-primary/25 bg-primary/10 p-4">
                  <p class="text-xs font-semibold uppercase tracking-widest text-accent">{capability.label}</p>
                  <p class="mt-1 text-lg font-bold text-white">{capability.value}</p>
                </div>
                <ul class="mt-5 space-y-2">
                  {capability.bullets.map((bullet) => (
                    <li class="flex gap-2 text-sm text-text-light">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mt-0.5 shrink-0 text-primary" aria-hidden="true">
                        <path d="M20 6 9 17l-5-5" />
                      </svg>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 overflow-hidden rounded-2xl border border-dark-border bg-dark-surface/50" data-reveal>
        <div class="grid grid-cols-1 divide-y divide-dark-border lg:grid-cols-3 lg:divide-x lg:divide-y-0">
          {productionTiers.map((tier) => (
            <div class="p-6">
              <p class="text-sm font-semibold text-primary">{tier.length}</p>
              <h3 class="mt-2 text-xl font-bold text-white">{tier.name}</h3>
              <dl class="mt-5 space-y-4 text-sm">
                <div>
                  <dt class="text-text-muted">Resolution</dt>
                  <dd class="mt-1 font-semibold text-white">{tier.quality}</dd>
                </div>
                <div>
                  <dt class="text-text-muted">Consistency Control</dt>
                  <dd class="mt-1 text-text-light">{tier.consistency}</dd>
                </div>
                <div>
                  <dt class="text-text-muted">Character Assets</dt>
                  <dd class="mt-1 text-text-light">{tier.asset}</dd>
                </div>
              </dl>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <CTASection
    title="Not Sure Which Service You Need?"
    description="Tell us about your project and we'll recommend the best approach for your goals and budget."
    primaryLabel="Start a Project"
    secondaryLabel="See Our Work"
  />
</BaseLayout>
