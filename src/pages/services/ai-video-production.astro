---
/**
 * Service: AI Video Production
 * Hero → Use Cases → Features → Process → Pricing → CTA
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import CTASection from '@components/ui/CTASection.astro';
import { localizePath, getLangFromUrl } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);

const useCases = [
  { title: 'Product Demos', description: 'Showcase product features with dynamic, AI-generated visuals that highlight every angle and benefit.', icon: '📦' },
  { title: 'Brand Commercials', description: 'Tell your brand story with cinematic AI-generated footage and professional voiceovers.', icon: '🎬' },
  { title: 'Explainer Videos', description: 'Simplify complex concepts with animated explainers powered by AI motion graphics.', icon: '💡' },
  { title: 'Social Media Ads', description: 'Scroll-stopping short-form videos optimized for TikTok, Reels, and Shorts.', icon: '📱' },
];

const features = [
  { title: 'Frontier AI Models', description: 'Powered by Seedance 2.0, Kling, and other state-of-the-art generation engines.' },
  { title: 'Cinematic Quality', description: 'AI-generated footage that rivals traditional production — at a fraction of the cost and time.' },
  { title: 'Rapid Turnaround', description: 'From brief to delivery in 24-48 hours for most projects, with same-day options available.' },
  { title: 'Unlimited Revisions', description: 'Iterate freely with AI — regenerate scenes, adjust voiceovers, and fine-tune until perfect.' },
];

const steps = [
  { step: '01', title: 'Brief & Concept', description: 'Share your goals, brand guidelines, and creative direction. We develop a concept and storyboard.' },
  { step: '02', title: 'AI Generation', description: 'Our pipeline generates video footage, selects voice talent, and produces a first draft within hours.' },
  { step: '03', title: 'Refinement', description: 'We fine-tune pacing, transitions, color grading, and audio based on your feedback — iterate as needed.' },
  { step: '04', title: 'Delivery', description: 'Receive final videos in all required formats, ready for deployment across your channels.' },
];
---

<BaseLayout
  title="AI Video Production — GlimoLab Services"
  description="From product showcases to brand stories, we create professional videos using state-of-the-art AI generation, voice synthesis, and automated editing."
>
  <!-- ============ Hero ============ -->
  <section class="relative overflow-hidden">
    <div class="bg-grid pointer-events-none absolute inset-0"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(0,102,255,0.15) 0%, transparent 70%);"
    >
    </div>

    <div class="relative mx-auto max-w-4xl px-4 py-24 sm:px-6 lg:py-32">
      <!-- Breadcrumb -->
      <a href={localizePath('/services', lang)} class="inline-flex items-center gap-1.5 text-sm text-text-muted transition-colors hover:text-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        All Services
      </a>

      <div class="animate-fade-in-up mt-6 inline-flex items-center gap-2 rounded-full border border-dark-border bg-dark-surface/50 px-4 py-1.5 text-xs font-medium text-accent backdrop-blur">
        AI Video Production
      </div>

      <h1 class="animate-fade-in-up mt-6 text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl" style="animation-delay: 0.1s;">
        AI Video Production
      </h1>

      <p class="animate-fade-in-up mt-6 max-w-2xl text-lg leading-relaxed text-text-muted" style="animation-delay: 0.2s;">
        From product showcases to brand stories, we create professional videos using state-of-the-art AI — delivering cinematic quality at unprecedented speed and scale.
      </p>
    </div>
  </section>

  <!-- ============ Use Cases ============ -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Use Cases"
        title="What We Create"
        subtitle="Versatile video content tailored to your marketing objectives."
      />
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {useCases.map((uc) => (
          <div class="glass-card glass-card-hover p-6 text-center" data-reveal>
            <div class="text-4xl">{uc.icon}</div>
            <h3 class="mt-3 text-base font-bold text-white">{uc.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Features ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Why GlimoLab"
        title="Key Features"
        subtitle="What sets our AI video production apart from traditional studios."
      />
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        {features.map((feature) => (
          <div class="glass-card glass-card-hover flex gap-4 p-6" data-reveal>
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 ring-1 ring-inset ring-primary/30">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-primary" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-white">{feature.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-text-muted">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Process ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="How It Works"
        title="Our Production Process"
        subtitle="A streamlined 4-step pipeline from concept to delivery."
      />
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {steps.map((step) => (
          <div class="glass-card glass-card-hover relative p-6" data-reveal>
            <span class="font-heading text-4xl font-bold text-primary/20">{step.step}</span>
            <h3 class="mt-2 text-base font-bold text-white">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ Pricing Hint ============ -->
  <section class="border-t border-dark-border py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <div class="glass-card p-10" data-reveal>
        <p class="font-heading text-sm font-semibold uppercase tracking-widest text-primary">Pricing</p>
        <h2 class="mt-3 text-2xl font-bold text-white sm:text-3xl">Premium Production, Launch Pricing</h2>
        <p class="mt-4 text-base leading-relaxed text-text-muted">
          Premium AI-assisted commercial video production in vertical, horizontal, and 4K cinematic formats, starting from $360 for each client’s first single-project video.
        </p>
        <p class="mt-4 text-sm text-text-muted">
          For the cost of one traditional studio shoot, GlimoLab can deliver a full month of campaign-ready video assets.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <CTASection
    title="Ready to Create Your Video?"
    description="Let's bring your vision to life with AI-powered production that delivers results."
    primaryLabel="Get a Quote"
    secondaryLabel="See Examples"
  />
</BaseLayout>
